generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model appointments {
  id          Int                  @id @default(autoincrement())
  business_id Int
  client_id   Int
  service_id  Int
  staff_id    Int
  start_time  DateTime             @db.DateTime(0)
  end_time    DateTime             @db.DateTime(0)
  status      appointments_status? @default(pending)
  total_price Decimal              @db.Decimal(10, 2)
  notes       String?              @db.Text
  created_at  DateTime?            @default(now()) @db.Timestamp(0)
  businesses  businesses           @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "appointments_ibfk_1")
  clients     clients              @relation(fields: [client_id], references: [id], onUpdate: Restrict, map: "appointments_ibfk_2")
  services    services             @relation(fields: [service_id], references: [id], onUpdate: Restrict, map: "appointments_ibfk_3")
  staff       staff                @relation(fields: [staff_id], references: [id], onUpdate: Restrict, map: "appointments_ibfk_4")

  @@index([client_id], map: "client_id")
  @@index([business_id, start_time, staff_id], map: "idx_appt_time")
  @@index([service_id], map: "service_id")
  @@index([staff_id], map: "staff_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model business_hours {
  id          Int        @id @default(autoincrement())
  business_id Int
  day_of_week Int        @db.TinyInt
  open_time   DateTime?  @db.Time(0)
  close_time  DateTime?  @db.Time(0)
  is_closed   Boolean?   @default(false)
  businesses  businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "business_hours_ibfk_1")

  @@unique([business_id, day_of_week], map: "unique_day_per_business")
}

model businesses {
  id             Int                 @id @default(autoincrement())
  owner_id       Int
  slug           String              @unique(map: "slug") @db.VarChar(50)
  name           String              @db.VarChar(100)
  category       businesses_category
  address        String?             @db.Text
  city           String?             @default("Colima") @db.VarChar(50)
  is_active      Boolean?            @default(true)
  created_at     DateTime?           @default(now()) @db.Timestamp(0)
  appointments   appointments[]
  business_hours business_hours[]
  owners         owners              @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "businesses_ibfk_1")
  clients        clients[]
  services       services[]
  staff          staff[]

  @@index([slug], map: "idx_business_slug")
  @@index([owner_id], map: "owner_id")
}

model clients {
  id             Int            @id @default(autoincrement())
  business_id    Int
  full_name      String         @db.VarChar(100)
  email          String?        @db.VarChar(150)
  phone          String?        @db.VarChar(20)
  internal_notes String?        @db.Text
  created_at     DateTime?      @default(now()) @db.Timestamp(0)
  appointments   appointments[]
  businesses     businesses     @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "clients_ibfk_1")

  @@index([business_id, phone], map: "idx_client_lookup")
}

model owners {
  id            Int          @id @default(autoincrement())
  full_name     String       @db.VarChar(100)
  email         String       @unique(map: "email") @db.VarChar(150)
  password_hash String       @db.VarChar(255)
  phone         String?      @db.VarChar(20)
  created_at    DateTime?    @default(now()) @db.Timestamp(0)
  updated_at    DateTime?    @default(now()) @db.Timestamp(0)
  businesses    businesses[]
}

model services {
  id               Int            @id @default(autoincrement())
  business_id      Int
  name             String         @db.VarChar(100)
  description      String?        @db.Text
  price            Decimal        @db.Decimal(10, 2)
  duration_minutes Int
  is_active        Boolean?       @default(true)
  appointments     appointments[]
  businesses       businesses     @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "services_ibfk_1")

  @@index([business_id], map: "idx_service_business")
}

model staff {
  id           Int            @id @default(autoincrement())
  business_id  Int
  name         String         @db.VarChar(100)
  email        String?        @db.VarChar(150)
  phone        String?        @db.VarChar(20)
  specialty    String?        @db.VarChar(100)
  is_active    Boolean?       @default(true)
  appointments appointments[]
  businesses   businesses     @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "staff_ibfk_1")

  @@index([business_id], map: "idx_staff_business")
}

enum businesses_category {
  health
  beauty
  professional
  fitness
  other
}

enum appointments_status {
  pending
  confirmed
  completed
  cancelled
  no_show   @map("no-show")
}
